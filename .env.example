# ============================================================================
# API Configuration for Toxic Comment Moderation System
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Keep your .env file PRIVATE - add it to .gitignore
# ============================================================================

# ============================================================================
# 1. OpenAI / LLM APIs (for enhanced summarization, detailed rationales)
# ============================================================================
# Optional: If you want to use GPT-3.5 or GPT-4 for better explanations
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
# Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview

# ============================================================================
# 2. Custom Moderation API (for ensemble moderation or additional checks)
# ============================================================================
# Optional: If you have a custom moderation service
CUSTOM_MODERATION_API_KEY=your-custom-api-key-here
CUSTOM_MODERATION_API_URL=https://your-moderation-api.example.com/api/classify

# ============================================================================
# 3. Logging & Analytics APIs (for audit trails and monitoring)
# ============================================================================
# Optional: Send decision logs to external service
LOGGING_API_KEY=your-logging-api-key-here
LOGGING_API_URL=https://your-logging-service.example.com/api/log

# ============================================================================
# 4. Feature Flags (Enable/Disable additional features)
# ============================================================================
# Set to 'true' to enable LLM-powered summarization in moderation-action stage
USE_LLM_SUMMARIZATION=false

# Set to 'true' to enable custom moderation API as ensemble
USE_CUSTOM_MODERATION_API=false

# Set to 'true' to send all decisions to external logging service
USE_EXTERNAL_LOGGING=false

# ============================================================================
# How to Use
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys in the .env file
# 3. Add .env to .gitignore (NEVER commit sensitive keys!)
# 4. The system will automatically load from .env on startup
#
# .gitignore entry:
# .env
# .env.local
# ============================================================================

# ============================================================================
# Configuration Priority (in order of precedence)
# ============================================================================
# 1. Programmatic parameters (passed when initializing)
# 2. .env file (if exists)
# 3. JSON config file (if specified)
# 4. Environment variables
# ============================================================================
